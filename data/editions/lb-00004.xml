	<text>
		<body>
			<div>
				<div type="page"><pb facs="#facs_1" n="1"/>
				<p facs="#facs_1_tr_1">
					<lb facs="#facs_1_tr_1_tl_1" n="N001"/>Lieber grav Vratl. Zue vornembung vnd consultirung des
					<lb facs="#facs_1_tr_1_tl_3" n="N002"/>vorhabenden berkhischen revisions process wollet ihr euch <w type="start">nach</w>
					<lb facs="#facs_1_tr_1_tl_4" n="N003"/><w type="end">folgender</w> räth gebrauchen, alß nemblich
					<lb facs="#facs_1_tr_1_tl_7" n="N004"/>von der böhmischen canzley
					<lb facs="#facs_1_l" n="N005"/>ihr selbest als praesens,
					<lb facs="#facs_1_tr_1_tl_8" n="N006"/>der von Greffenburg,
					<lb facs="#facs_1_tr_1_tl_9" n="N007"/>von Waldorff
					<lb facs="#facs_1_l_2" n="N008"/>vnd Goll,
					<lb facs="#facs_1_tr_1_tl_12" n="N009"/>aus den reichshoffrath
					<lb facs="#facs_1_tr_1_tl_11" n="N010"/>Andler,
					<lb facs="#facs_1_tr_1_tl_13" n="N011"/>Bruininx,
					<lb facs="#facs_1_l_4" n="N012"/>vnd Pordtner,
					<lb facs="#facs_1_tr_1_tl_15" n="N013"/>aus der N. Ö. regierung
					<lb facs="#facs_1_tr_1_tl_16" n="N014"/>baron Bucelleni
					<lb facs="#facs_1_tr_1_tl_17" n="N015"/>Pinel,
					<lb facs="#facs_1_tr_1_tl_18" n="N016"/>Erhardt
					<lb facs="#facs_1_tr_1_tl_19" n="N017"/>vnd Frey.
					<lb facs="#facs_1_tr_1_tl_20" n="N018"/>Vnd wollet auch gedachten räthen bey vernembung der sachen in
					<lb facs="#facs_1_tr_1_tl_21" n="N019"/>meinen nahmen vordragen, das sie hiri<choice><expan/><abbr>nn</abbr></choice>en nichts ex respectu personar<choice><expan/><abbr>um</abbr></choice>
					<lb facs="#facs_1_tr_1_tl_22" n="N020"/>vel passione aliqua handlen, sondern das jenige einrathen vnd
					<lb facs="#facs_1_tr_1_tl_23" n="N021"/>schliessen sollen, was sie der justiz vnd ihren gewißen gemeß zue sein
					<lb facs="#facs_1_tr_1_tl_24" n="N022"/>befünden vnd ihnen <unclear>nur</unclear> vor den strengen richterstuel Gottes an jenen
					<lb facs="#facs_1_tr_1_tl_25" n="N023"/>grossen dag <corr>z</corr>ue verandtwordthen getrawen werden. Vnd verbleibe eüch
					<lb facs="#facs_1_l_1" n="N024"/>mitt beharlichen <choice><expan>kayserlichen</expan><abbr>kay.</abbr></choice> vnd <choice><expan>königlichen</expan><abbr>kön.</abbr></choice> hulden vnd genaden wolgewogen
					<lb facs="#facs_1_tr_1_tl_28" n="N025"/>Leopoldt
					<lb facs="#facs_1_tr_1_tl_27" n="N026"/>Wienn, <choice><expan/><abbr>den</abbr></choice> 20. Junij 1672
				</p>
				</div><div type="page"><pb facs="#facs_2" n="2"/>
				</div><div type="page"><pb facs="#facs_3" n="3"/>
				</div><div type="page"><pb facs="#facs_4" n="4"/>
			</div></div>
