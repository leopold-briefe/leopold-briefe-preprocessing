	<text>
		<body>
			<div>
				<div type="page"><pb facs="#facs_1" n="1"/>
				<p facs="#facs_1_tr_1">
					<lb facs="#facs_1_tr_1_tl_3" n="N001"/>Lieber Vratl. Aus beylag ersehet ihr die vrsachen, <w type="start">wa</w>
					<lb facs="#facs_1_tr_1_tl_4" n="N002"/><w type="end">rvmb</w> der <choice><expan>graf</expan><abbr>g.</abbr></choice> Steffan von Wurmb sich von der <w type="start">lantag</w>
					<lb facs="#facs_1_tr_1_tl_5" n="N003"/><w type="end">comission</w> <corr>z</corr>ue endtschüetten vermaindt. Waillen ich
					<lb facs="#facs_1_tr_1_tl_6" n="N004"/>aber selbe nitt vor genuegsamb erhöblich finde,
					<lb facs="#facs_1_l" n="N005"/>also wollet ihr ihne alßo straxs mundtlich andeütten,
					<lb facs="#facs_1_tr_1_tl_9" n="N006"/>das er sich alsobaldt nach Brun verfuegen vnd seiner
					<lb facs="#facs_1_tr_1_tl_10" n="N007"/>comission in termino den anfang geben solle.
					<lb facs="#facs_1_tr_1_tl_11" n="N008"/>In sain processen vnd causis wirdt müessen vorgesehen
					<lb facs="#facs_1_tr_1_tl_12" n="N009"/>werden, ne reipublicae causae absens dannum patiat<choice><expan/><abbr>ur</abbr></choice>.
					<lb facs="#facs_1_tr_1_tl_13" n="N010"/>Vnd verbleibe euch mitt beharlichen <choice><expan>kayserlichen</expan><abbr>kay.</abbr></choice> hulden
					<lb facs="#facs_1_l_3" n="N011"/>vnd genaden wolgwogen
					<lb facs="#facs_1_l_1" n="N012"/>Leopoldt
					<lb facs="#facs_1_l_2" n="N013"/>Den 28. <choice><expan>Januarii</expan><abbr>Jan.</abbr></choice> 1668
				</p>
				</div><div type="page"><pb facs="#facs_2" n="2"/>
				</div><div type="page"><pb facs="#facs_3" n="3"/>
				</div><div type="page"><pb facs="#facs_4" n="4"/>
				<p facs="#facs_4_tr_1">
					<lb facs="#facs_4_tr_1_tl_1" n="N001"/>An graven Vratel
					<lb facs="#facs_4_tr_1_tl_2" n="N002"/>von Stherenberg
				</p>
